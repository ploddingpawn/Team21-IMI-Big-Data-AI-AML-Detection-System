# =============================================================================
# AML EXPLANATION ENGINE — Environment Variable Template
# Copy this file to .env and fill in your real values.
# Never commit your real .env file.
# =============================================================================

# --- Backend Selection ---
MODEL_BACKEND=gemini

# --- Hugging Face ---
HF_TOKEN=your_hf_token_here
HF_DATASET_REPO=scotiabank-big-data-team/2026-scotiabank-imi-big-data-ai

# --- Gemini (only used if MODEL_BACKEND=gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Rate Limit ---
SECONDS_BETWEEN_CALLS=5

# --- Local LLM (only used if MODEL_BACKEND=local_llm) ---
GGUF_LOCAL_PATH=./models/Llama-3.2-3B-Instruct-Q4_K_M.gguf
GGUF_HF_REPO=bartowski/Llama-3.2-3B-Instruct-GGUF
GGUF_FILENAME=Llama-3.2-3B-Instruct-Q4_K_M.gguf

# --- HF Input File Paths (relative inside HF_DATASET_REPO) ---
HF_HIGH_RISK_EVIDENCE_PATH=outputs/high_risk_evidence.csv

# --- HF Output File Path ---
# Leave unset to auto-select based on MODEL_BACKEND:
# gemini -> outputs/gemini_output_explanations.csv
# local_llm -> outputs/llama_output_explanations.csv
# HF_EXPLANATION_OUTPUT_PATH=outputs/gemini_output_explanations.csv
