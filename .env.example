# =============================================================================
# AML EXPLANATION ENGINE — Environment Variable Template
# Copy this file to .env and fill in your real values.
# Never commit your real .env file.
# =============================================================================

# --- Backend Selection ---
MODEL_BACKEND=gemini

# --- Hugging Face ---
HF_TOKEN=your_hf_token_here
HF_DATASET_REPO=your-org/your-repo-name

# --- Gemini (only used if MODEL_BACKEND=gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Rate Limit ---
SECONDS_BETWEEN_CALLS=5
MAX_CUSTOMERS_PER_RUN=1

# --- Local LLM (only used if MODEL_BACKEND=local_llm) ---
GGUF_LOCAL_PATH=./models/Llama-3.2-3B-Instruct-Q4_K_M.gguf
GGUF_HF_REPO=bartowski/Llama-3.2-3B-Instruct-GGUF
GGUF_FILENAME=Llama-3.2-3B-Instruct-Q4_K_M.gguf

# --- HF Input File Paths (relative inside HF_DATASET_REPO) ---
HF_MODEL_OUTPUT_PATH=models/model_output.csv
HF_ISOLATION_RESULTS_PATH=models/isolation_forest_results.csv
HF_FEATURES_PATH=features/customer_features_engineered.csv
HF_AML_LIBRARY_PATH=AML_RedFlags_Database.xlsx

# --- HF Output File Path ---
HF_EXPLANATION_OUTPUT_PATH=models/model_output_explanations.csv
